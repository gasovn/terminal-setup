# Catppuccin Mocha color theme for Fish shell
# https://github.com/catppuccin/fish

set -g fish_color_normal cdd6f4          # Text
set -g fish_color_command 89b4fa         # Blue
set -g fish_color_keyword cba6f7         # Mauve
set -g fish_color_quote a6e3a1           # Green
set -g fish_color_redirection f5c2e7     # Pink
set -g fish_color_end fab387             # Peach
set -g fish_color_error f38ba8           # Red
set -g fish_color_param f2cdcd           # Flamingo
set -g fish_color_comment 7f849c         # Overlay1
set -g fish_color_selection --background=45475a  # Surface1
set -g fish_color_search_match --background=45475a
set -g fish_color_operator 94e2d5        # Teal
set -g fish_color_escape eba0ac          # Maroon
set -g fish_color_autosuggestion 6c7086  # Overlay0
set -g fish_color_cancel f38ba8          # Red
set -g fish_color_cwd f9e2af            # Yellow
set -g fish_color_user 94e2d5            # Teal
set -g fish_color_host 89b4fa            # Blue
set -g fish_color_host_remote a6e3a1     # Green
set -g fish_color_status f38ba8          # Red
set -g fish_color_valid_path --underline

# Pager (tab completions)
set -g fish_pager_color_progress 6c7086  # Overlay0
set -g fish_pager_color_prefix f5c2e7    # Pink
set -g fish_pager_color_completion cdd6f4 # Text
set -g fish_pager_color_description 7f849c # Overlay1
set -g fish_pager_color_selected_background --background=45475a
